{
  "name": "vstypingspeed",
  "displayName": "VS Typing Speed",
  "description": "Track live coding WPM and session typing stats in the VS Code status bar.",
  "version": "0.0.1",
  "publisher": "willtheorangeguy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/willtheorangeguy/typing-speed-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/willtheorangeguy/typing-speed-vscode/issues"
  },
  "homepage": "https://github.com/willtheorangeguy/typing-speed-vscode#readme",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vstypingspeed.showStats",
    "onCommand:vstypingspeed.resetSessionStats",
    "onCommand:vstypingspeed.togglePause"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vstypingspeed.showStats",
        "title": "VS Typing Speed: Show Current Stats"
      },
      {
        "command": "vstypingspeed.togglePause",
        "title": "VS Typing Speed: Pause or Resume Tracking"
      },
      {
        "command": "vstypingspeed.resetSessionStats",
        "title": "VS Typing Speed: Reset Session Stats"
      }
    ],
    "configuration": {
      "title": "VS Typing Speed",
      "properties": {
        "vstypingspeed.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable typing-speed tracking and the status bar item."
        },
        "vstypingspeed.idleThresholdSeconds": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 60,
          "description": "How long typing can pause before live WPM drops back to zero."
        },
        "vstypingspeed.refreshIntervalMs": {
          "type": "number",
          "default": 1000,
          "minimum": 250,
          "maximum": 5000,
          "description": "How often the status bar refreshes."
        },
        "vstypingspeed.pasteThresholdCharacters": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 200,
          "description": "Ignore insertions larger than this many characters so pastes do not inflate stats."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile",
    "check-types": "tsc --noEmit",
    "lint": "npm run check-types",
    "pretest": "npm run compile",
    "test": "mocha out/test/**/*.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "@types/vscode": "^1.120.0",
    "mocha": "^11.1.0",
    "typescript": "^6.0.3"
  }
}
